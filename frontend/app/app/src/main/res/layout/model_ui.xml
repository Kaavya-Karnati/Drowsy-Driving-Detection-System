<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Drowsy Detection Title -->

            <TextView
                android:id="@+id/drowsyDetectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="48dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/drowsy_detection"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Green Status Indicator -->
            <View
                android:id="@+id/statusIndicatorGreen"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/status_indicator_green"
                app:layout_constraintBottom_toBottomOf="@id/drowsyDetectionTitle"
                app:layout_constraintStart_toEndOf="@id/drowsyDetectionTitle"
                app:layout_constraintTop_toTopOf="@id/drowsyDetectionTitle" />

            <!-- Red Status Indicator -->
            <View
                android:id="@+id/statusIndicatorRed"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/status_indicator_red"
                app:layout_constraintBottom_toBottomOf="@id/drowsyDetectionTitle"
                app:layout_constraintStart_toEndOf="@id/statusIndicatorGreen"
                app:layout_constraintTop_toTopOf="@id/drowsyDetectionTitle" />


            <!-- Feeling Sleepy Popup -->
            <ImageView
                android:id="@+id/coffeeIcon"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_marginTop="64dp"
                android:src="@drawable/break_popup_img"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.168"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/drowsyDetectionTitle" />

            <TextView
                android:id="@+id/feelingSleepy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/inter"
                android:text="@string/feeling_sleepy"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.218"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/coffeeIcon" />


            <TextView
                android:id="@+id/timeForBreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter_medium"
                android:text="@string/time_for_a_break"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.234"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/feelingSleepy" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWakeUp"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="40dp"
                android:layout_marginEnd="24dp"
                android:backgroundTint="#FF3366"
                android:fontFamily="@font/inter_medium"
                android:text="@string/wake_up"
                android:textColor="@android:color/white"
                android:textSize="36sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/timeForBreak" />

            <!-- Start Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="115dp"
                android:layout_height="100dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="#4CAF50"
                android:fontFamily="@font/inter_medium"
                android:text="@string/start"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                app:cornerRadius="20dp"
                app:layout_constraintEnd_toStartOf="@id/btnStop"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btnWakeUp" />

            <!-- Stop Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStop"
                android:layout_width="115dp"
                android:layout_height="100dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="40dp"
                android:backgroundTint="#F44336"
                android:fontFamily="@font/inter_medium"
                android:text="@string/stop"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                app:cornerRadius="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnStart"
                app:layout_constraintTop_toBottomOf="@id/btnWakeUp" />

            <Button
                android:id="@+id/button2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="openCamera"
                android:text="@string/model"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.196"
                app:layout_constraintStart_toEndOf="@+id/statusIndicatorRed"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.071" />

            <Button
                android:id="@+id/openCVButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="openCV"
                android:text="@string/opencv"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.542"
                app:layout_constraintStart_toEndOf="@+id/coffeeIcon"
                app:layout_constraintTop_toBottomOf="@+id/button2"
                app:layout_constraintVertical_bias="0.045" />

            <Button
                android:id="@+id/alertButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:onClick="openAlert"
                android:text="@string/alert_driver"
                app:layout_constraintBottom_toTopOf="@+id/btnWakeUp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.577"
                app:layout_constraintStart_toEndOf="@+id/coffeeIcon"
                app:layout_constraintTop_toBottomOf="@+id/openCVButton"
                app:layout_constraintVertical_bias="0.193" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>