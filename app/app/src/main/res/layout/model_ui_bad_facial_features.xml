<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Drowsy Detection Title -->
            <TextView
                android:id="@+id/drowsyDetectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="48dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/drowsy_detection"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Green Status Indicator -->
            <View
                android:id="@+id/statusIndicatorGreen"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/status_indicator_green"
                app:layout_constraintBottom_toBottomOf="@id/drowsyDetectionTitle"
                app:layout_constraintStart_toEndOf="@id/drowsyDetectionTitle"
                app:layout_constraintTop_toTopOf="@id/drowsyDetectionTitle" />

            <!-- Warning Circle Icon -->
            <ImageView
                android:id="@+id/warningCircleIcon"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="64dp"
                android:src="@drawable/ic_warning_circle"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/drowsyDetectionTitle" />

            <!-- Facial Features Not Detected message -->
            <TextView
                android:id="@+id/facialFeaturesMsg"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="40dp"
                android:fontFamily="@font/inter_semibold"
                android:gravity="center"
                android:text="Facial features not detected!\nAdjust Camera"
                android:textColor="#E53935"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/warningCircleIcon" />

            <!-- Turn on lights hint -->
            <TextView
                android:id="@+id/lightsHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:text="Turn on lights if dark 🌙"
                android:textColor="#333333"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/facialFeaturesMsg" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Start Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="115dp"
        android:layout_height="100dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#4CAF50"
        android:fontFamily="@font/inter_medium"
        android:text="@string/start"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toStartOf="@id/btnStop"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Stop Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="115dp"
        android:layout_height="100dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#F44336"
        android:fontFamily="@font/inter_medium"
        android:text="@string/stop"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnStart" />

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>