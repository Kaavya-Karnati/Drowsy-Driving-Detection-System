            <!-- Visual Alert Banner: shown when eyes closed >= 3s (audio alert trigger) -->
            <TextView
                android:id="@+id/visualAlertPopUp"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="24dp"
                android:background="#E53935"
                android:gravity="center"
                android:padding="16dp"
                android:text="@string/wake_up"
                android:textColor="#FFFFFF"
                android:textSize="45sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/drowsyDetectionTitle" />

            <!-- Break Popup Image: shown when 3+ yawns detected -->
            <ImageView
                android:id="@+id/breakPopUp"
                android:layout_width="138dp"
                android:layout_height="168dp"
                android:layout_marginTop="32dp"
                android:src="@drawable/break_popup_with_text"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/visualAlertPopUp" />

            <!-- Close/Dismiss X Button for break popup -->
            <ImageView
                android:id="@+id/closePopup"
                android:layout_width="43dp"
                android:layout_height="36dp"
                android:src="@drawable/cross"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="@id/breakPopUp"
                app:layout_constraintStart_toStartOf="@id/breakPopUp"
                app:layout_constraintTop_toTopOf="@id/breakPopUp"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintVertical_bias="0.0" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

    <!-- Start Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="115dp"
        android:layout_height="100dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#4CAF50"
        android:fontFamily="@font/inter_medium"
        android:text="@string/start"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toStartOf="@id/btnStop"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Stop Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="115dp"
        android:layout_height="100dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#F44336"
        android:fontFamily="@font/inter_medium"
        android:text="@string/stop"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnStart" />

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>