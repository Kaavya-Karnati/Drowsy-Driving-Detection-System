<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:text="@string/drowsy_driver"
            android:textColor="#000000"
            android:textSize="30sp"
            android:textStyle="bold" />


        <ImageView
            android:layout_width="160dp"
            android:layout_height="111dp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/app_logo"
            android:src="@drawable/drowsy_driver_logo" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            android:fontFamily="@font/inter_semibold"
            android:text="@string/forgot_password_2"
            android:textColor="#000000"
            android:textSize="20sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColorHint="@color/input_box_color"
            app:boxStrokeColor="#E0E0E0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fpFirstName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/first_name"
                android:inputType="textPersonName"
                android:padding="16dp"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColorHint="@color/input_box_color"
            app:boxStrokeColor="#E0E0E0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fpLastName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/last_name"
                android:inputType="textPersonName"
                android:padding="16dp"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColorHint="@color/input_box_color"
            app:boxStrokeColor="#E0E0E0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fpEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/registered_email"
                android:inputType="textEmailAddress"
                android:padding="16dp"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColorHint="@color/input_box_color"
            app:boxStrokeColor="#E0E0E0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fpAnswer1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/sec_q_1"
                android:padding="16dp"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textColorHint="@color/input_box_color"
            app:boxStrokeColor="#E0E0E0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fpAnswer2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/sec_q_2"
                android:padding="16dp"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:textColorHint="@color/input_box_color"
            app:boxStrokeColor="#E0E0E0">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/fpAnswer3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/sec_q_3"
                android:padding="16dp"
                android:textColor="@color/black" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/errorBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:alpha="0"
            android:background="@drawable/error_banner_background"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/wrong_answer"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:visibility="gone" />

        <TextView
            android:id="@+id/passBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:alpha="0"
            android:background="@drawable/pass_banner_background"
            android:gravity="center"
            android:padding="12dp"
            android:text="@string/password_changed"
            android:textColor="@android:color/black"
            android:textStyle="bold"
            android:visibility="gone" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="15dp"
            android:backgroundTint="@android:color/black"
            android:fontFamily="@font/inter_medium"
            android:text="@string/verify"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/backToLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/back_to_login"
            android:textColor="@color/input_box_color"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>