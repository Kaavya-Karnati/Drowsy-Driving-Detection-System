<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:opencv="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.opencv.android.JavaCameraView
        android:id="@+id/my_camera"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        opencv:show_fps="true"
        opencv:camera_id="1"/>
    <!-- following the opencv docs to put 'any', but most likely we should specify later on -->

    <!-- we can hide this afterwords, just for dev purposes -->
    <TextView
        android:id="@+id/detectionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#66000000"
        android:padding="8dp"
        android:text="@string/drowsy"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ahmed's code-->

    <TextView
        android:id="@+id/errorBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/wrong_answer_please_try_again"
        android:background="@drawable/error_banner_background"
        android:textColor="@android:color/black"
        android:textStyle="bold"
        android:padding="12dp"
        android:gravity="center"
        android:visibility="gone"
        android:alpha="0"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/detectionText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/visualAlertPopUp"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="#E53935"
        android:gravity="center"
        android:text="@string/wake_up"
        android:textColor="#FFFFFF"
        android:textSize="45sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.1" />

    <!-- Voice feedback (after repeated alerts) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/voiceFeedbackOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:background="#DD000000"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/voiceFeedbackContent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/voiceFeedbackStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:textColor="@android:color/white"
                android:textSize="16sp" />

            <LinearLayout
                style="?android:attr/buttonBarStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnVoiceYes"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/yes_i_m_alert" />

                <Button
                    android:id="@+id/btnVoiceGetHelp"
                    style="?android:attr/buttonBarButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="@string/get_help" />
            </LinearLayout>

            <TextView
                android:id="@+id/voiceEscalationCountdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="@string/_5"
                android:textColor="@android:color/white"
                android:textSize="48sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnVoiceCancelEmergency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:text="@string/cancel_emergency" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>