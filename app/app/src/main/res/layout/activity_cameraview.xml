<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:opencv="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.opencv.android.JavaCameraView
        android:id="@+id/my_camera"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        opencv:show_fps="true"
        opencv:camera_id="any"/>
    <!-- following the opencv docs to put 'any', but most likely we should specify later on -->

    <!-- we can hide this afterwords, just for dev purposes -->
    <TextView
        android:id="@+id/detectionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#66000000"
        android:padding="8dp"
        android:text="Drowsy%: "
        android:textColor="@android:color/white"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Ahmed's code-->

    <TextView
        android:id="@+id/errorBanner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Wrong answer! Please try again!"
        android:background="@drawable/error_banner_background"
        android:textColor="@android:color/black"
        android:textStyle="bold"
        android:padding="12dp"
        android:gravity="center"
        android:visibility="gone"
        android:alpha="0"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/detectionText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>