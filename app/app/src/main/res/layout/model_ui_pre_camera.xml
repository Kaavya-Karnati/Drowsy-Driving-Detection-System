<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Drowsy Detection Title -->
            <TextView
                android:id="@+id/drowsyDetectionTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="48dp"
                android:fontFamily="@font/inter_semibold"
                android:text="@string/drowsy_detection"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Red Status Indicator (pre-camera: red only) -->
            <View
                android:id="@+id/statusIndicatorRed"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/status_indicator_red"
                app:layout_constraintBottom_toBottomOf="@id/drowsyDetectionTitle"
                app:layout_constraintStart_toEndOf="@id/drowsyDetectionTitle"
                app:layout_constraintTop_toTopOf="@id/drowsyDetectionTitle" />

            <!-- Pre-camera info card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/preCameraCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/drowsyDetectionTitle">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Card Title -->
                    <TextView
                        android:id="@+id/cardTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_semibold"
                        android:text="Before Starting Detection"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/warningIcon"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Warning Icon -->
                    <ImageView
                        android:id="@+id/warningIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_warning"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/cardTitle"
                        app:layout_constraintBottom_toBottomOf="@id/cardTitle" />

                    <!-- Instructions List -->
                    <TextView
                        android:id="@+id/instructions"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/inter"
                        android:text="1. Ensure camera is mounted on a stable location\n2. Ensure camera is facing you head on\n3. Ensure eyes and mouth are not covered\n4. Ensure their is enough lighting (if driving during night)"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:lineSpacingExtra="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/cardTitle" />

                    <!-- Best results note -->
                    <TextView
                        android:id="@+id/bestResults"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter"
                        android:text="For best results, avoid wearing sunglasses and yawning with your mouth uncovered"
                        android:textColor="#555555"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/instructions" />

                    <!-- Icons row: sunglasses ban + volume -->
                    <ImageView
                        android:id="@+id/noSunglassesIcon"
                        android:layout_width="114dp"
                        android:layout_height="98dp"
                        android:layout_marginTop="12dp"
                        android:src="@drawable/ic_no_sunglasses"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/bestResults" />

                    <!-- Upward arrows icon (next to volume) -->

                    <!-- Invisible bottom anchor -->

                    <ImageView
                        android:id="@+id/arrowsIcon"
                        android:layout_width="59dp"
                        android:layout_height="83dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_up_arrow"
                        app:layout_constraintBottom_toBottomOf="@id/volumeIcon"
                        app:layout_constraintStart_toEndOf="@id/volumeIcon"
                        app:layout_constraintTop_toTopOf="@id/volumeIcon"
                        app:layout_constraintVertical_bias="0.0" />

                    <ImageView
                        android:id="@+id/volumeIcon"
                        android:layout_width="77dp"
                        android:layout_height="87dp"
                        android:layout_marginStart="72dp"
                        android:src="@drawable/ic_volume_up"
                        app:layout_constraintBottom_toBottomOf="@id/noSunglassesIcon"
                        app:layout_constraintStart_toEndOf="@id/noSunglassesIcon"
                        app:layout_constraintTop_toTopOf="@id/noSunglassesIcon"
                        app:layout_constraintVertical_bias="0.0" />

                    <View
                        android:id="@+id/bottomAnchor"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        app:layout_constraintTop_toBottomOf="@id/noSunglassesIcon"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Start Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStart"
        android:layout_width="115dp"
        android:layout_height="100dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#4CAF50"
        android:fontFamily="@font/inter_medium"
        android:text="@string/start"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toStartOf="@id/btnStop"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Stop Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStop"
        android:layout_width="115dp"
        android:layout_height="100dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#F44336"
        android:fontFamily="@font/inter_medium"
        android:text="@string/stop"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnStart" />

    <include
        android:id="@+id/bottomNavigation"
        layout="@layout/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>