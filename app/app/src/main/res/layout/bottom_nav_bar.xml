<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@drawable/navbar_border">

    <View
        android:id="@+id/navIndicator"
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:background="@android:color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- Home Icon -->
    <ImageView
        android:id="@+id/homeLogo"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/home_page_logo"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/navIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/modelLogo"
        app:layout_constraintHorizontal_chainStyle="spread" />

    <!-- Model Icon -->
    <ImageView
        android:id="@+id/modelLogo"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/model_page_logo"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/navIndicator"
        app:layout_constraintStart_toEndOf="@id/homeLogo"
        app:layout_constraintEnd_toStartOf="@id/faqLogo" />

    <!-- FAQ Icon -->
    <FrameLayout
        android:id="@+id/faqLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/navIndicator"
        app:layout_constraintStart_toEndOf="@id/modelLogo"
        app:layout_constraintEnd_toStartOf="@id/profileLogo">

        <ImageView
            android:id="@+id/faqImg"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/faq_page_logo"
            />

    </FrameLayout>

    <!-- Profile Icon -->
    <ImageView
        android:id="@+id/profileLogo"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/default_profile_icon"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/navIndicator"
        app:layout_constraintStart_toEndOf="@id/faqLogo"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>