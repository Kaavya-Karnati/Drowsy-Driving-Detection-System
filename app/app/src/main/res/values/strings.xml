    <!-- FAQ PAGE -->
    <string name="FAQAnswer1">No, an account is not necessary to use our app. However, user features like alert records, preferences, and health information are only available to registered users.</string>
    <string name="FAQQuestion1"><font color="000000"><b>Do I need an account?</b></font></string>
    <string name="FAQQuestion2"><font color="000000"><b>How do you detect drowsy driving?</b></font></string>
    <string name="FAQAnswer2">We use a in-house trained YOLOv8 model to detect user facial features, such as closed eyes and yawning.</string>
    <string name="FAQQuestion3"><font color="000000"><b>Is this app considered a medical device?</b></font></string>
    <string name="FAQAnswer3">No! Our intention for this application is to provide alerts to those who may fall asleep during drives.</string>
    <string name="FAQQuestion4"><font color="000000"><b>Do you store any photos of users?</b></font></string>
    <string name="FAQAnswer4">No, all images and recordings are directly processed on your device, and never reach our servers. Your data is yours.</string>
